APP_DEBUG=false
APP_URL=
APP_PORT=3000
# Bot 介面語系：zh_TW（預設、正式支援）、zh、zh_CN、en、ja。
# zh/zh_CN 目前都使用繁體中文字串；en/ja 為實驗性，部分新功能與自然語言解析仍偏繁中。
APP_LANG=
APP_WEBHOOK_PATH=
APP_API_TIMEOUT=
APP_MAX_GROUPS=
APP_MAX_USERS=
APP_MAX_PROMPT_MESSAGES=
APP_MAX_PROMPT_TOKENS=
APP_MAX_PROMPT_AGE=
APP_INIT_PROMPT=

HUMAN_NAME=
HUMAN_INIT_PROMPT=

BOT_NAME=
BOT_INIT_PROMPT=
BOT_TONE=
BOT_DEACTIVATED=false

ERROR_MESSAGE_DISABLED=false

ENABLE_IMAGE_GENERATION=true
ENABLE_TRANSCRIPTION=true
ENABLE_VISION=true
ENABLE_SEARCH=true

GROUP_REPLY_REQUIRES_MENTION=false

ENABLE_URL_SUMMARY=false

# 天氣查詢（`天氣 台北`）。資料來自 Open-Meteo，免費、無需 API key；預設 false。
ENABLE_WEATHER=
# 預報天數，1–7，預設 5。
WEATHER_FORECAST_DAYS=
# 同地點快取秒數，預設 600。
WEATHER_CACHE_TTL=
# 每日天氣推播（`每日天氣 台北 8`）。走 Push API 計 LINE 額度，需同時開 ENABLE_WEATHER
# 並套用 0010 migration，且沿用提醒的每分鐘 Supabase Cron（REMINDER_CRON_SECRET）。預設 false。
ENABLE_WEATHER_PUSH=
# 未指定時刻時的預設推送當地小時（0–23），預設 7。
WEATHER_DAILY_DEFAULT_HOUR=
# 每次 cron 最多入列的到期天氣訂閱數，預設 50。
WEATHER_DAILY_MAX_PER_RUN=
URL_FETCH_TIMEOUT=
URL_FETCH_MAX_BYTES=
URL_FETCH_MAX_CHARS=

VERCEL_DEPLOY_HOOK_URL=

BLOB_READ_WRITE_TOKEN=

OPENAI_TIMEOUT=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_COMPLETION_MODEL=
OPENAI_COMPLETION_TEMPERATURE=
OPENAI_COMPLETION_MAX_TOKENS=
OPENAI_COMPLETION_FREQUENCY_PENALTY=
OPENAI_COMPLETION_PRESENCE_PENALTY=
OPENAI_IMAGE_GENERATION_MODEL=
OPENAI_IMAGE_GENERATION_SIZE=
OPENAI_IMAGE_GENERATION_QUALITY=
OPENAI_IMAGE_GENERATION_TIMEOUT=
OPENAI_VISION_MODEL=
OPENAI_TRANSCRIPTION_MODEL=
# run trace 成本估算：每 1K token 的美元單價（依你主要 completion 模型自行填）。
# 兩者皆設才會計 cost_usd，否則 runs 只記 token 數、成本留空。價格會變動，非永久價目表。
OPENAI_PRICE_PER_1K_PROMPT=
OPENAI_PRICE_PER_1K_COMPLETION=

LINE_TIMEOUT=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

SERPAPI_TIMEOUT=
SERPAPI_API_KEY=
SERPAPI_LOCATION=

# 6.0 起 Supabase Postgres 是必要的 durable state，不再提供記憶體或 Vercel env fallback。
# serverless 請用 Supabase connection pooler 連線字串。
DATABASE_URL=
DATABASE_POOL_MAX=
# Supabase 建議設為 Dashboard 下載的 CA PEM；可使用 \n 代表換行。
DATABASE_SSL_CA=
# 32-byte base64 key：加密 durable job payload，並將 channel user id 轉為 HMAC 代碼。
DATA_ENCRYPTION_KEY=

# webhook 固定先 durable 入列，再於同一次調用內 drain 佇列。
# 單次 drain 最多處理幾個 job。
WORKER_MAX_JOBS=
# job 租約秒數；預設 120，需長於 Vercel function 的最長執行時間。
WORKER_LEASE_SECONDS=
# job 最大嘗試次數，預設 3。重試只會重送、不會重跑付費的 AI（由 jobs.result checkpoint 保證），
# 且重送同一個 reply token 不會產生重複訊息。
WORKER_MAX_ATTEMPTS=

# 行程新增／模糊時間追問／修改。需先套用 0001–0006 並設好 DATABASE_URL；預設 false。
ENABLE_SCHEDULE=
# 沒有使用者時區時的預設 IANA 時區。
SCHEDULE_DEFAULT_TIMEZONE=
# 行程解析的 completion token 上限（聊天用的 64 塞不下一份行程 JSON）。
SCHEDULE_MAX_TOKENS=
# 行程草稿等待確認的秒數，逾時即失效。
SCHEDULE_CONFIRM_TTL=

# 任務／待辦（新增／列出／完成／重開／刪除）。只存 Supabase，不建立 Calendar 行程；
# 開啟 ENABLE_GOOGLE_TASKS 並重新授權後可同步 Google Tasks。需先在同一 Google Cloud project
# 啟用 Google Tasks API（OAuth tasks scope 不會代替啟用 API），並套用 0007–0008、0011。
ENABLE_TASKS=
# 「我的任務」每頁筆數，1–6；預設 6（LINE quick reply 上限）。
TASK_LIST_LIMIT=6

# 到點提醒；需先套用 0005 migration，並以 Supabase Cron 每分鐘呼叫 endpoint。
ENABLE_REMINDERS=false
# 至少 32 字元的隨機 Bearer secret；到點提醒與 Google 同步重試共用此每分鐘 worker。
# Vercel Sensitive env 與 Supabase Vault 必須相同。
REMINDER_CRON_SECRET=
# 每次 cron 最多 drain 的提醒／Google 同步／狀態通知 jobs，預設 20。
REMINDER_WORKER_MAX_JOBS=
# 提醒晚於預定時刻超過這麼多分鐘就視為過期、跳過不送，預設 120。
REMINDER_STALE_MINUTES=
# 多重（lead）提醒：除到點提醒外，額外在「提前 N 分鐘」各排一個提醒。逗號分隔的正整數分鐘，
# 例如 60,1440＝提前 1 小時與 1 天。需開 ENABLE_REMINDERS；最多 5 個、每個不超過一年。
# 預設空＝只有到點提醒（向後相容）；去重排序、上限 5 個。
REMINDER_OFFSETS=
# 只供 npm run db:configure-reminders 使用，不會由 app 讀取。
REMINDER_CRON_URL=
# 提醒偏好指令（需 0009 migration）：安靜時段 22-8／安靜時段 關閉、暫停提醒、恢復提醒。

# Google Calendar：新增／查詢／完成／刪除改走使用者授權的 Google 行事曆。
# 先套用 0004 migration，並在 Google Cloud 建立 Web application OAuth client。
ENABLE_GOOGLE_CALENDAR=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 必須與 Google Cloud Authorized redirect URI 完全一致。
GOOGLE_OAUTH_REDIRECT_URI=
# 預設 primary；也可填指定且由使用者擁有的 calendar id。
GOOGLE_CALENDAR_ID=primary
# 一次性 OAuth state / PKCE verifier 有效秒數，預設 600。
GOOGLE_OAUTH_STATE_TTL=
# Google Calendar → 本地 inbound 同步（sync token 輪詢）：Google 端刪除→本地回收；
# 外部修改（限非週期 timed 行程）→ 本地更新並重排提醒。需套用 0012＋0013 migration
# 與開 ENABLE_GOOGLE_CALENDAR（修改重排提醒另需 ENABLE_REMINDERS）。預設 false。
ENABLE_GOOGLE_CALENDAR_INBOUND=
# 每個帳號至少間隔幾秒才輪詢一次（節流），預設 300。
CALENDAR_INBOUND_INTERVAL=
# 每次 cron 最多挑幾個帳號輪詢，預設 20。
CALENDAR_INBOUND_MAX_PER_RUN=
# Google Tasks outbound 同步（新增／完成／重開／刪除→Google Tasks）。需套用 0011、與 Calendar
# 共用 OAuth；既有連結需重新授權 tasks scope，callback 會回填既有任務。預設 false。
ENABLE_GOOGLE_TASKS=
# 同步目標 task list，預設 @default。
GOOGLE_TASKS_LIST_ID=
# Google Tasks → 本地 inbound 同步（updatedMin 輪詢）：Google 端完成／重開、刪除、標題、
# 備註回收到 Supabase（不回收 due，精確期限以本地為權威）。需套用 0014 migration 與
# 開 ENABLE_GOOGLE_TASKS。預設 false。
ENABLE_GOOGLE_TASKS_INBOUND=
# 每帳號至少間隔幾秒才輪詢一次（節流），預設 300；每次 cron 挑帳號上限，預設 20。
TASKS_INBOUND_INTERVAL=
TASKS_INBOUND_MAX_PER_RUN=
